digraph G {
  graph [
    rankdir=TB,
    splines=ortho,
    nodesep=0.55,
    ranksep=0.75,
    bgcolor="white",
    labelloc="t",
    label="FHD - System obsługi zamówień: funkcje główne",
    fontname="Arial",
    fontsize=20
  ];
  node [
    shape=box,
    style="rounded,filled",
    fillcolor="#f8fbff",
    color="#3b6ea8",
    penwidth=1.4,
    fontname="Arial",
    fontsize=12,
    margin="0.14,0.08"
  ];
  edge [
    color="#3b6ea8",
    arrowsize=0.6,
    arrowhead=none,
    penwidth=1.2
  ];

  "root" [label="0. System obsługi zamówień"];
  "f1" [label="1. Obsługa zamówień"];
  "f2" [label="2. Obsługa klientów"];
  "f3" [label="3. Obsługa rejonów"];
  "f4" [label="4. Obsługa wyrobów"];
  "f5" [label="5. Obsługa magazynu"];
  "root" -> "f1";
  "root" -> "f2";
  "root" -> "f3";
  "root" -> "f4";
  "root" -> "f5";
}
